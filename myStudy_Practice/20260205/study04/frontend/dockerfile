# 1단계: 빌드 스테이지 (소스 코드를 컴파일하여 정적 파일 생성)
# node:24.13.0 이미지를 가져와서 'build'라는 별칭을 붙입니다.
FROM node:24.13.0 as build

# 컨테이너 내부의 작업 디렉토리를 /app으로 설정합니다.
WORKDIR /app

# 라이브러리 설치를 위해 package.json과 lock 파일을 먼저 복사합니다.
# (파일이 변경되지 않았다면 캐시를 사용하여 npm install 속도를 높입니다.)
COPY package.json ./
RUN npm install 

# 현재 내 컴퓨터의 모든 소스 코드를 컨테이너의 /app 폴더로 복사합니다.
COPY . .

# 리액트/뷰 프로젝트를 빌드합니다. 결과물은 보통 /app/dist 폴더에 생깁니다.
RUN npm run build


# 2단계: 실행 스테이지 (빌드된 파일만 Nginx로 서빙)
# 가벼운 웹 서버인 nginx 이미지를 불러옵니다. (버전은 1.28 대신 stable 권장)
FROM nginx:1.28

# [핵심] 'build' 스테이지에서 생성된 /app/dist 폴더의 내용만 
# Nginx가 웹 페이지를 보여주는 경로(/usr/share/nginx/html)로 복사합니다.
COPY --from=build /app/dist /usr/share/nginx/html

# 내가 만든 nginx 설정 파일(default.conf)을 컨테이너 안에 덮어씌웁니다.
# 리액트 라우터 사용 시 새로고침 에러를 방지하는 설정이 보통 여기에 포함됩니다.
COPY ./default.conf /etc/nginx/conf.d/default.conf

# 이 컨테이너는 80번 포트를 외부로 노출할 것임을 명시합니다.
EXPOSE 80

# Nginx 서버를 백그라운드가 아닌 포그라운드(Foreground)에서 실행합니다.
# (도커 컨테이너가 꺼지지 않고 계속 유지되게 합니다.)
CMD ["nginx","-g","daemon off;"]